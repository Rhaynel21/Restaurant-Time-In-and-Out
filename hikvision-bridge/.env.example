# ── Hikvision device (copy to .env and fill in) ──────────────────────────────
# Base URL of the device on your LAN. Use http:// unless HTTPS is enabled.
HIK_HOST=http://192.168.1.64
HIK_USER=admin
HIK_PASS=your-device-password

# ── Polling ──────────────────────────────────────────────────────────────────
POLL_INTERVAL_MS=1000
# Access-control event filter. 5 = access event, minor 0 = all types. Leave as-is
# unless your device uses different codes.
HIK_EVENT_MAJOR=5
HIK_EVENT_MINOR=0
# Device clock timezone offset (Philippines = +08:00).
HIK_TZ_OFFSET=+08:00
# Ignore a repeat scan from the same person within this many seconds.
DEBOUNCE_SECONDS=60

# ── Branch fallback (used if an employee has no branch in Firestore) ──────────
DEFAULT_BRANCH_ID=kio-bgc
DEFAULT_BRANCH_NAME=Qui - BGC

# ── Device identity (shown on the manager portal's Devices panel) ─────────────
DEVICE_ID=kio-terminal-1
DEVICE_NAME=Qui Biometric Terminal

# ── Tamper / anti-fraud detection ────────────────────────────────────────────
# Declare the device offline after this many consecutive failed polls.
OFFLINE_AFTER_FAILS=3
# Flag a possible tampering / forced-entry attempt when this many failed/unknown
# scans happen within the window (seconds).
FAILED_AUTH_THRESHOLD=5
FAILED_AUTH_WINDOW_SECONDS=120
# Optional: extra Hikvision event minor codes to treat as a case/tamper alarm,
# comma-separated (leave blank if unsure — burst + offline detection still work).
HIK_TAMPER_MINORS=
