# Copy this file to .env and fill in your Firebase project's web config values.
# Find them in: Firebase Console → Project settings → Your apps → Web app → SDK setup.
# EXPO_PUBLIC_ vars are bundled into the client and are NOT secrets — access to data
# is controlled by Firestore rules + Auth. Never put real secrets behind EXPO_PUBLIC_.
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=
EXPO_PUBLIC_FIREBASE_MEASUREMENT_ID=
